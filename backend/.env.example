# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host/krino

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# Paste the full JSON content of your Firebase service account key
FIREBASE_SERVICE_ACCOUNT_JSON='{...}'

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Recall.ai ─────────────────────────────────────────────────────────────────
RECALL_API_KEY=...
# HMAC secret used to verify incoming Recall.ai webhooks (set in Recall dashboard)
RECALL_WEBHOOK_SECRET=...

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...

# ── Redis (Celery broker + backend) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@krino.ai

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-min-32-chars
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,https://your-frontend.web.app

# ── Google Calendar (tenant OAuth — stored per tenant in DB, not here) ────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
